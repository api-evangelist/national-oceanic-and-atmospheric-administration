  "info": {
    "_postman_id": "049f2d07-9003-4281-b985-8320db0adfee",
    "name": "NOAA CO-OPS Data API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The NOAA Center for Operational Oceanographic Products and Services (CO-OPS) Data API provides observations and predictions from CO-OPS stations including water levels, tides, currents, meteorological data, and derived products. Operated by the National Oceanic and Atmospheric Administration (NOAA), U.S. Department of Commerce.\n\nContact Support:\n Name: CO-OPS User Services\n Email: co-ops.userservices@noaa.gov",
